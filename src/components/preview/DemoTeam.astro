---
const { colors, headingFont, bodyFont, borderRadius, shadowSm, spacing } =
    Astro.props

const team = [
    {
        name: "Laura Méndez",
        role: "Directora de diseño",
        image: "https://i.pravatar.cc/300?img=1",
    },
    {
        name: "Carlos Ruiz",
        role: "Arquitecto principal",
        image: "https://i.pravatar.cc/300?img=3",
    },
    {
        name: "Marta Solís",
        role: "Diseñadora de interiores",
        image: "https://i.pravatar.cc/300?img=5",
    },
    {
        name: "David Herrera",
        role: "Director de proyectos",
        image: "https://i.pravatar.cc/300?img=8",
    },
]
---

<section
    class="demo-team"
    style={`background-color: ${colors.primary}; padding: ${spacing[7]}px 0;`}
>
    <div class="team-container">
        <p class="section-label" style={`color: ${colors.accent};`}>
            Nuestro equipo
        </p>
        <h2
            class="section-title"
            style={`font-family: '${headingFont}', Georgia, serif; color: ${colors.background};`}
        >
            Las personas detrás de cada proyecto
        </h2>

        <div class="team-grid">
            {
                team.map((member) => (
                    <div
                        class="team-card"
                        style={`background-color: ${colors.background}; border-radius: ${borderRadius.lg}; box-shadow: ${shadowSm};`}
                    >
                        <div
                            class="member-image-wrap"
                            style={`border-radius: ${borderRadius.md}; overflow: hidden;`}
                        >
                            <img
                                src={member.image}
                                alt={member.name}
                                class="member-image"
                                loading="lazy"
                            />
                        </div>
                        <h3
                            class="member-name"
                            style={`font-family: '${headingFont}', Georgia, serif; color: ${colors.text};`}
                        >
                            {member.name}
                        </h3>
                        <p
                            class="member-role"
                            style={`font-family: '${bodyFont}', system-ui, sans-serif; color: ${colors.muted};`}
                        >
                            {member.role}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .team-container {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .section-label {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 8px;
        text-align: center;
    }

    .section-title {
        font-size: 32px;
        margin-bottom: 48px;
        text-align: center;
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .team-card {
        padding: 20px;
        text-align: center;
        overflow: hidden;
    }

    .member-image-wrap {
        width: 100%;
        aspect-ratio: 1;
        margin-bottom: 16px;
    }

    .member-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .member-name {
        font-size: 16px;
        margin-bottom: 4px;
    }

    .member-role {
        font-size: 13px;
    }

    @media (max-width: 768px) {
        .section-title {
            font-size: 26px;
            margin-bottom: 32px;
        }

        .team-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }
    }

    @media (max-width: 480px) {
        .team-container {
            padding: 0 16px;
        }

        .team-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .team-card {
            padding: 16px;
        }

        .member-name {
            font-size: 14px;
        }

        .member-role {
            font-size: 12px;
        }
    }
</style>
