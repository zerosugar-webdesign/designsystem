---
const { shadows, colors, headingFont, borderRadius } = Astro.props

const shadowList = [
    { name: "Small", key: "sm", cssVar: "--shadow-sm", value: shadows.sm },
    { name: "Medium", key: "md", cssVar: "--shadow-md", value: shadows.md },
    { name: "Large", key: "lg", cssVar: "--shadow-lg", value: shadows.lg },
]
---

<section class="shadows-section">
    <div class="shadows-container">
        <p class="section-label">05 · Sombras</p>
        <h2
            class="section-title"
            style={`font-family: '${headingFont}', Georgia, serif;`}
        >
            Elevación y profundidad
        </h2>

        <div class="shadows-grid">
            {
                shadowList.map((shadow) => (
                    <div class="shadow-item">
                        <div
                            class="shadow-card"
                            style={`background-color: ${colors.background}; border-radius: ${borderRadius.lg}; box-shadow: ${shadow.value};`}
                        >
                            <p
                                class="shadow-name"
                                style={`font-family: '${headingFont}', Georgia, serif; color: ${colors.primary};`}
                            >
                                {shadow.name}
                            </p>
                        </div>
                        <div class="shadow-code">
                            <p class="shadow-var">{shadow.cssVar}</p>
                            <p class="shadow-value">{shadow.value}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .shadows-section {
        background-color: #e1e1e1;
        padding: 64px 0;
    }

    .shadows-container {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .section-label {
        font-size: 12px;
        font-weight: 700;
        color: #555;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .section-title {
        font-size: 32px;
        color: #555;
        margin-bottom: 40px;
    }

    .shadows-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .shadow-item {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .shadow-card {
        padding: 40px 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .shadow-name {
        font-size: 24px;
        font-weight: 600;
    }

    .shadow-code {
        background-color: #0a0a0a;
        border-radius: 8px;
        padding: 12px 16px;
    }

    .shadow-var {
        font-family: monospace;
        font-size: 11px;
        color: #d4ff00;
        margin-bottom: 6px;
    }

    .shadow-value {
        font-family: monospace;
        font-size: 10px;
        color: #666;
        line-height: 1.5;
        word-break: break-all;
    }

    @media (max-width: 768px) {
        .shadows-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .shadow-card {
            padding: 32px 24px;
        }

        .section-title {
            font-size: 26px;
            margin-bottom: 32px;
        }
    }

    @media (max-width: 480px) {
        .shadows-section {
            padding: 48px 0;
        }

        .shadows-container {
            padding: 0 16px;
        }

        .shadow-card {
            padding: 24px 16px;
        }

        .shadow-name {
            font-size: 20px;
        }

        .shadow-code {
            padding: 10px 12px;
        }
    }
</style>
