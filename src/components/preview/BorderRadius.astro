---
const { borderRadius, primaryColor, headingFont, shadowSm } = Astro.props

const radiusList = [
    { name: "Small", cssVar: "--radius-sm", value: borderRadius.sm },
    { name: "Medium", cssVar: "--radius-md", value: borderRadius.md },
    { name: "Large", cssVar: "--radius-lg", value: borderRadius.lg },
    { name: "Full", cssVar: "--radius-full", value: borderRadius.full },
]
---

<section class="radius-section">
    <div class="radius-container">
        <p class="section-label">06 · Border radius</p>
        <h2
            class="section-title"
            style={`font-family: '${headingFont}', Georgia, serif;`}
        >
            Redondeo de esquinas
        </h2>

        <div class="radius-grid">
            {
                radiusList.map((radius) => (
                    <div class="radius-item">
                        <div
                            class="radius-box"
                            style={`background-color: ${primaryColor}; border-radius: ${radius.value}; box-shadow: ${shadowSm};`}
                        />
                        <p class="radius-name">{radius.name}</p>
                        <p class="radius-value">{radius.value}</p>
                        <p class="radius-var">{radius.cssVar}</p>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .radius-section {
        background-color: #0a0a0a;
        padding: 64px 0;
    }

    .radius-container {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .section-label {
        font-size: 12px;
        font-weight: 700;
        color: #555;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .section-title {
        font-size: 32px;
        color: #ffffff;
        margin-bottom: 40px;
    }

    .radius-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    .radius-item {
        text-align: center;
    }

    .radius-box {
        width: 100%;
        aspect-ratio: 1;
    }

    .radius-name {
        font-size: 14px;
        font-weight: 600;
        color: #ffffff;
        margin-top: 16px;
    }

    .radius-value {
        font-family: monospace;
        font-size: 12px;
        color: #888;
        margin-top: 4px;
    }

    .radius-var {
        font-family: monospace;
        font-size: 11px;
        color: #555;
        margin-top: 2px;
    }

    @media (max-width: 768px) {
        .radius-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .section-title {
            font-size: 26px;
            margin-bottom: 32px;
        }

        .radius-box {
            max-width: 160px;
            margin: 0 auto;
        }
    }

    @media (max-width: 480px) {
        .radius-section {
            padding: 48px 0;
        }

        .radius-container {
            padding: 0 16px;
        }

        .radius-box {
            max-width: 120px;
        }
    }
</style>
